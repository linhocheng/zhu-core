# 築自我工程 — 環境變數樣板
# 複製成 .env 後填值。.env 已 gitignore。
# Node 22+ 用 --env-file 直接讀；或 source 進 shell。

# Gemini embedding API key（沿用 molowe / ailive 的）
GEMINI_API_KEY=

# Firebase service account JSON（單行字串）— 沿用 molowe / ailive 的 SA
FIREBASE_SERVICE_ACCOUNT_JSON=

# 可選：bridge URL（distill / health 用）
# ZHU_BRIDGE_URL=https://bridge.soul-polaroid.work

# 可選：override embedding model
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
