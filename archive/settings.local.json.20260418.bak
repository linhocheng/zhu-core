{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git clone*)",
      "Bash(git config*)",
      "Bash(git checkout*)",
      "Bash(git merge*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git show*)",
      "Bash(npm run build*)",
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npx *)",
      "Bash(curl *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(vercel *)",
      "Bash(sleep *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(node *)",
      "Bash(rm *)",
      "Bash(sed *)",
      "Bash(env *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(gcloud *)",
      "Bash(*&&*)",
      "Edit",
      "Write",
      "Read",
      "Bash(claude --version)",
      "Bash(claude auth *)",
      "Bash(claude --debug *)",
      "Bash(open \"https://claude.ai/settings/profile\")"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -r /)*",
      "Bash(*DROP TABLE*)",
      "Bash(*password*)",
      "Bash(*secret*)"
    ],
    "defaultMode": "bypassPermissions"
  }
}
